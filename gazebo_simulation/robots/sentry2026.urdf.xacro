<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sentry">
  <xacro:arg name="use_sim" default="true"/>
  <xacro:arg name="use_gimbal_control" default="false"/>
  <xacro:arg name="use_planar_controller" default="false"/>

  <xacro:property name="mesh_prefix" value="package://gazebo_simulation/meshes/sentry2026"/>

  <material name="dark_gray">
    <color rgba="0.25098039 0.25098039 0.25098039 1"/>
  </material>
  <material name="light_gray">
    <color rgba="0.69803922 0.69803922 0.69803922 1"/>
  </material>
  <material name="wheel_front">
    <color rgba="0.92941176 0.92941176 0.92941176 1"/>
  </material>
  <material name="wheel_rear">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="warm_gray">
    <color rgba="0.64705882 0.61960784 0.58823529 1"/>
  </material>
  <material name="upper_gray">
    <color rgba="0.86666667 0.86666667 0.89019608 1"/>
  </material>

  <link name="chassis_link">
    <visual>
      <geometry><mesh filename="${mesh_prefix}/base_link.STL"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision name="body_collision">
      <origin xyz="0.0105748 0.0007029 0.071449"/>
      <geometry><box size="0.594 0.594 0.118672"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0188632 0.0318286 0.0620274"/>
      <mass value="4.2677209"/>
      <inertia ixx="0.0259148" ixy="-0.0001191" ixz="0.0005407"
               iyy="0.0250381" iyz="-0.0000228" izz="0.0481419"/>
    </inertial>
  </link>

  <!-- v1.3 wheels: visual mesh, spherical ground contact, and passive continuous joint. -->
  <xacro:macro name="wheel" params="name mesh material mass_origin joint_origin joint_rpy">
    <link name="${name}_link">
      <visual>
        <geometry><mesh filename="${mesh_prefix}/${mesh}"/></geometry>
        <material name="${material}"/>
      </visual>
      <collision>
        <origin xyz="0.02 0 0" rpy="0 1.5707963 0"/>
        <geometry><sphere radius="0.065985"/></geometry>
      </collision>
      <inertial>
        <origin xyz="${mass_origin}"/>
        <mass value="0.3453588"/>
        <inertia ixx="0.0003098" ixy="-0.0000002" ixz="0"
                 iyy="0.0001729" iyz="0" izz="0.0001722"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="chassis_link"/>
      <child link="${name}_link"/>
      <origin xyz="${joint_origin}" rpy="${joint_rpy}"/>
      <axis xyz="-1 0 0"/>
    </joint>
    <gazebo reference="${name}_link">
      <gravity>true</gravity>
      <mu1>0.05</mu1>
      <mu2>0.05</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:wheel name="wheel_fl" mesh="wheel_fl_link.STL" material="wheel_front"
    mass_origin="0.0081125 -0.0000928 -0.0000122"
    joint_origin="0.2197598 0.2098879 0.025" joint_rpy="1.5707963 0 0.7853982"/>
  <xacro:wheel name="wheel_fr" mesh="wheel_fr_link.STL" material="wheel_front"
    mass_origin="0.0081125 -0.0000928 -0.0000122"
    joint_origin="0.2197598 -0.2084821 0.025" joint_rpy="1.5707963 0 -0.7853982"/>
  <xacro:wheel name="wheel_rl" mesh="wheel_rl_link.STL" material="wheel_rear"
    mass_origin="0.0081125 -0.0000928 -0.0000122"
    joint_origin="-0.1986102 0.2098879 0.025" joint_rpy="1.5707963 0 2.3561945"/>
  <xacro:wheel name="wheel_rr" mesh="wheel_rr_link.STL" material="wheel_rear"
    mass_origin="0.0081125 -0.0000928 -0.0000122"
    joint_origin="-0.1986102 -0.2084821 0.025" joint_rpy="1.5707963 0 -2.3561945"/>

  <link name="gimbal_yaw_big_link">
    <visual>
      <geometry><mesh filename="${mesh_prefix}/gimbal_yaw_big_link.STL"/></geometry>
      <material name="warm_gray"/>
    </visual>
    <collision>
      <origin xyz="-0.113232 -0.01231 0.11775"/>
      <geometry><box size="0.288505 0.44902 0.1035"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.1358475 0.0049467 0.1275701"/>
      <mass value="1.694088"/>
      <inertia ixx="0.0218449" ixy="0.0004953" ixz="0.000041"
               iyy="0.021004" iyz="0.0000236" izz="0.0245309"/>
    </inertial>
  </link>

  <link name="gimbal_yaw_small_link">
    <visual>
      <geometry><mesh filename="${mesh_prefix}/gimbal_yaw_small_link.STL"/></geometry>
      <material name="light_gray"/>
    </visual>
    <collision>
      <origin xyz="0.0000005 -0.0109641 0.0425"/>
      <geometry><box size="0.1379722 0.1599005 0.057"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0075279 -0.0307755 0.0341618"/>
      <mass value="0.2475866"/>
      <inertia ixx="0.0001335" ixy="-0.0000035" ixz="-0.0000013"
               iyy="0.0001488" iyz="0.0000026" izz="0.0002131"/>
    </inertial>
  </link>

  <link name="gimbal_pitch_lower_link">
    <visual>
      <geometry><mesh filename="${mesh_prefix}/gimbal_pitch_lower_link.STL"/></geometry>
      <material name="light_gray"/>
    </visual>
    <collision>
      <origin xyz="0.046889 0.0069809 0.110322" rpy="1.2680269 1.5707963 -0.2371063"/>
      <geometry><box size="0.246271 0.179873 0.07439"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.0437227 0.0121797 0.1256049"/>
      <mass value="0.4473433"/>
      <inertia ixx="0.0009368" ixy="-0.0000055" ixz="-0.0000015"
               iyy="0.0010207" iyz="-0.0000585" izz="0.0002177"/>
    </inertial>
  </link>

  <link name="gimbal_pitch_upper_link">
    <visual>
      <geometry><mesh filename="${mesh_prefix}/gimbal_pitch_upper_link.STL"/></geometry>
      <material name="upper_gray"/>
    </visual>
    <collision>
      <origin xyz="-0.0388241 -0.0976083 0.0012"/>
      <geometry><box size="0.1555171 0.2498641 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.027817 -0.1111812 0.0077809"/>
      <mass value="0.6340389"/>
      <inertia ixx="0.0006559" ixy="0.0001031" ixz="0.0000008"
               iyy="0.0003513" iyz="0.0000024" izz="0.0009083"/>
    </inertial>
  </link>

  <joint name="gimbal_yaw_big_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="gimbal_yaw_big_link"/>
    <origin xyz="0.0105748 0.0007029 0.03"/>
    <axis xyz="0 0 1"/>
    <!-- Required by ros2_control; continuous joints remain angle-unbounded. -->
    <!-- Extra speed margin lets big yaw catch a 3 rad/s spinning chassis. -->
    <limit effort="100" velocity="5"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <joint name="gimbal_yaw_small_joint" type="revolute">
    <parent link="gimbal_yaw_big_link"/>
    <child link="gimbal_yaw_small_link"/>
    <origin xyz="0.084 -0.024 0.07"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-3.14" upper="0" effort="100" velocity="3"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <joint name="gimbal_pitch_lower_joint" type="revolute">
    <parent link="gimbal_yaw_small_link"/>
    <child link="gimbal_pitch_lower_link"/>
    <origin xyz="-0.0429366 -0.0023341 0.038"/>
    <axis xyz="-0.9985257 -0.0542812 0"/>
    <limit lower="0" upper="1.41" effort="100" velocity="3"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <joint name="gimbal_pitch_upper_joint" type="revolute">
    <parent link="gimbal_pitch_lower_link"/>
    <child link="gimbal_pitch_upper_link"/>
    <origin xyz="0.1021791 0.0086869 0.2049761"/>
    <axis xyz="0.9985257 0.0542812 0"/>
    <limit lower="-0.7" upper="1.41" effort="100" velocity="3"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>

  <!-- MID-360 mount copied from simple_livox.urdf.xacro. -->
  <link name="mid360_link">
    <visual>
      <geometry>
        <mesh filename="package://gazebo_simulation/models/mid360/meshes/mid360.dae"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <collision name="mid360_collision">
      <geometry><box size="0.08 0.12 0.08"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0"
               iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <joint name="mid360_mount_joint" type="fixed">
    <parent link="gimbal_yaw_big_link"/>
    <child link="mid360_link"/>
    <origin xyz="0.0668 -0.1623 0.1195" rpy="0 0 0"/>
  </joint>

  <!-- Sensor parameters are taken from models/mid360/model.sdf. -->
  <gazebo reference="mid360_link">
    <gravity>false</gravity>
    <sensor name="mid360_lidar" type="gpu_lidar">
      <ignition_frame_id>mid360_link</ignition_frame_id>
      <pose>0 0 0.03 0 0 0</pose>
      <topic>/model/sentry/mid360/scan</topic>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1500</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>6.2831852</max_angle>
          </horizontal>
          <vertical>
            <samples>32</samples>
            <resolution>1</resolution>
            <min_angle>-0.12217304764</min_angle>
            <max_angle>0.90757121104</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.15</min>
          <max>15.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.01</stddev>
      </noise>
    </sensor>
    <sensor name="mid360_imu" type="imu">
      <ignition_frame_id>mid360_link</ignition_frame_id>
      <topic>/model/sentry/mid360/imu</topic>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>200</update_rate>
    </sensor>
  </gazebo>

  <gazebo reference="chassis_link">
    <gravity>true</gravity>
  </gazebo>
  <gazebo reference="gimbal_yaw_big_link"><gravity>true</gravity></gazebo>
  <gazebo reference="gimbal_yaw_small_link"><gravity>true</gravity></gazebo>
  <gazebo reference="gimbal_pitch_lower_link"><gravity>true</gravity></gazebo>
  <gazebo reference="gimbal_pitch_upper_link"><gravity>true</gravity></gazebo>

  <xacro:if value="$(arg use_sim)">
    <xacro:if value="$(arg use_gimbal_control)">
    <ros2_control name="GazeboSimSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
      <!-- Passive v1.3 wheel joints: state only, no drivetrain command interface. -->
      <joint name="wheel_fl_joint">
        <state_interface name="position"><param name="initial_value">0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="wheel_fr_joint">
        <state_interface name="position"><param name="initial_value">0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="wheel_rl_joint">
        <state_interface name="position"><param name="initial_value">0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="wheel_rr_joint">
        <state_interface name="position"><param name="initial_value">0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="gimbal_yaw_big_joint">
        <command_interface name="effort"/>
        <state_interface name="position"><param name="initial_value">0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="gimbal_yaw_small_joint">
        <command_interface name="effort"/>
        <state_interface name="position"><param name="initial_value">0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="gimbal_pitch_lower_joint">
        <command_interface name="effort"/>
        <state_interface name="position"><param name="initial_value">0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="gimbal_pitch_upper_joint">
        <command_interface name="effort"/>
        <state_interface name="position"><param name="initial_value">0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
    </xacro:if>

    <gazebo>
      <!-- Keep collisions against the world, but never collide links of this robot together. -->
      <self_collide>false</self_collide>
      <xacro:if value="$(arg use_planar_controller)">
      <plugin filename="libplanar_wrench_controller.so"
              name="sentry_simulation::PlanarWrenchController">
        <link_name>chassis_link</link_name>
        <topic>/model/sentry/cmd_vel</topic>
        <linear_gain_x>100.0</linear_gain_x>
        <linear_gain_y>100.0</linear_gain_y>
        <linear_integral_gain_x>20.0</linear_integral_gain_x>
        <linear_integral_gain_y>20.0</linear_integral_gain_y>
        <linear_derivative_gain_x>2.0</linear_derivative_gain_x>
        <linear_derivative_gain_y>2.0</linear_derivative_gain_y>
        <linear_integral_limit>2.0</linear_integral_limit>
        <angular_gain_z>2.5</angular_gain_z>
        <angular_integral_gain_z>0.5</angular_integral_gain_z>
        <angular_derivative_gain_z>0.05</angular_derivative_gain_z>
        <angular_integral_limit>2.0</angular_integral_limit>
        <heading_gain>6.0</heading_gain>
        <heading_integral_gain>0.5</heading_integral_gain>
        <heading_derivative_gain>1.5</heading_derivative_gain>
        <heading_integral_limit>1.0</heading_integral_limit>
        <heading_deadband>0.01</heading_deadband>
        <max_force>80.0</max_force>
        <max_torque>6.0</max_torque>
        <max_linear_speed>3.0</max_linear_speed>
        <max_angular_speed>4.0</max_angular_speed>
        <command_timeout>0.2</command_timeout>
        <support_slip_compliance>1.0</support_slip_compliance>
        <!-- Let contact and gravity follow terrain height and slope naturally. -->
        <vertical_gain>0.0</vertical_gain>
        <vertical_damping>0.0</vertical_damping>
        <tilt_gain>0.0</tilt_gain>
        <tilt_damping>0.0</tilt_damping>
        <max_vertical_force>250.0</max_vertical_force>
        <max_tilt_torque>30.0</max_tilt_torque>
      </plugin>
      </xacro:if>
      <xacro:if value="$(arg use_gimbal_control)">
        <plugin filename="libgz_ros2_control-system.so"
                name="gz_ros2_control::GazeboSimROS2ControlPlugin">
          <parameters>$(find gazebo_simulation)/config/sentry2026/controllers.yaml</parameters>
          <hold_joints>true</hold_joints>
        </plugin>
      </xacro:if>
      <plugin filename="gz-sim-odometry-publisher-system"
              name="gz::sim::systems::OdometryPublisher">
        <dimensions>2</dimensions>
        <odom_frame>odom</odom_frame>
        <robot_base_frame>chassis_link</robot_base_frame>
        <odom_publish_frequency>50</odom_publish_frequency>
        <odom_topic>/model/sentry/odometry</odom_topic>
        <tf_topic>/model/sentry/pose</tf_topic>
      </plugin>
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher">
        <topic>/world/default/model/sentry/joint_state</topic>
      </plugin>
    </gazebo>
  </xacro:if>
</robot>
